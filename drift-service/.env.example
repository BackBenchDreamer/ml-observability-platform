# Redis Configuration
REDIS_HOST=localhost
REDIS_PORT=6379
STREAM_NAME=ml-events
ALERT_STREAM_NAME=ml-alerts
CONSUMER_GROUP=drift-detector
CONSUMER_NAME=drift-worker-1

# PostgreSQL Configuration
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=ml_observability
POSTGRES_USER=mlobs
POSTGRES_PASSWORD=mlobs_pass

# Drift Detection Configuration
BASELINE_WINDOW_SIZE=100
SLIDING_WINDOW_SIZE=100
DRIFT_THRESHOLD_PSI=0.2
DRIFT_THRESHOLD_KS=0.05

# Service Configuration
METRICS_PORT=8000
LOG_LEVEL=INFO
CHECK_INTERVAL_MS=1000